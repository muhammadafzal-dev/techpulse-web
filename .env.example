# Google AdSense publisher ID (format: ca-pub-XXXXXXXXXXXXXXXX)
# Find in AdSense dashboard → Account → Account information.
# Exposed to client (NEXT_PUBLIC_) — the AdSense loader needs it client-side.
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-0000000000000000

# Ad unit slot IDs (10+ digit numeric).
# Create one ad unit per slot in AdSense → Ads → By ad unit AFTER account approval.
# Leave blank before approval — AdUnit components render null until set.
NEXT_PUBLIC_ADSENSE_SLOT_HOME_MID=
NEXT_PUBLIC_ADSENSE_SLOT_HOME_CTA=
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE=
